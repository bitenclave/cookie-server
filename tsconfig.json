{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "types": ["node", "vitest/globals"]
  },
  "include": ["api/**/*.ts", "index.ts", "src/**/*.ts", "drizzle.config.ts"],
  "exclude": ["dist", "node_modules"]
}
